# Normalize line endings to LF in the repository for all text files.
# On checkout, Windows gets CRLF, Unix/macOS gets LF.
* text=auto

# Source files — always LF
*.c     text eol=lf
*.h     text eol=lf
*.cmake text eol=lf

# Build system
CMakeLists.txt  text eol=lf
Kconfig*        text eol=lf
sdkconfig*      text eol=lf

# Config and documentation
*.md    text eol=lf
*.txt   text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.json  text eol=lf

# Binaries — no line ending normalization
*.bin   binary
*.elf   binary
*.hex   binary
